{
  "python.analysis.autoImportCompletions": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.egg-info": true
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/apps/api-service/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/apps/api-service/src",
    "${workspaceFolder}/apps/agent-service/src",
    "${workspaceFolder}/packages/python-domain/src"
  ],
  "python.analysis.enableEditableInstalls": true,
  "python.analysis.autoSearchPaths": false
}
